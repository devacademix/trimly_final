# Strict, non-hoisted install by default — keeps dependencies explicit.
# NestJS, Prisma and Next.js all work correctly under pnpm's isolated node_modules.
strict-peer-dependencies=false
auto-install-peers=true
# Turborepo + Next.js benefit from this being available.
shamefully-hoist=false
# Pin the registry for reproducible installs.
registry=https://registry.npmjs.org/
