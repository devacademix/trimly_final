{
  "name": "trimly",
  "version": "0.1.0",
  "private": true,
  "description": "Trimly Business OS — Enterprise multi-tenant salon & appointment booking SaaS platform.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "db:migrate": "pnpm --filter @trimly/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @trimly/database db:migrate:deploy",
    "db:generate": "pnpm --filter @trimly/database db:generate",
    "db:seed": "pnpm --filter @trimly/database db:seed",
    "db:studio": "pnpm --filter @trimly/database db:studio",
    "db:reset": "pnpm --filter @trimly/database db:reset",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
