# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs
dist/
build/
.next/
out/
*.tsbuildinfo
turbo-*.json
.turbo/

# Coverage / test artifacts
coverage/
.nyc_output/

# Env files (NEVER commit secrets)
.env
.env.*
!.env.example
!.env.*.example

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Prisma
packages/database/src/generated/

# Docker
docker-compose.override.yml

# ── Flutter / Dart ─────────────────────────────────────────
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/.pub-cache/
**/.pub/
**/build/
**/.fvm/
**/coverage/
.flutter-plugins
.flutter-plugins-dependencies

