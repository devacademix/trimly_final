# ─────────────────────────────────────────────────────────────────────────────
# Trimly Business OS — environment template.
# Copy to `.env` (root) and fill in real values. `.env` is gitignored.
# Every key here is consumed by a real SDK call; no mocks.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=Trimly
API_PREFIX=/api/v1
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
# Comma-separated. Requests outside this list are 429'd (throttle config).
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=300

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Connection pool URL. Used by Prisma at runtime.
DATABASE_URL=postgresql://trimly:trimly@localhost:5434/trimly?schema=public
# Used only for migrations (no pooler / direct connection).
DIRECT_DATABASE_URL=postgresql://trimly:trimly@localhost:5434/trimly?schema=public

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (JWT + OTP) ─────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-32-chars-min
JWT_REFRESH_SECRET=change-me-refresh-secret-32-chars-min
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# OTP (SMS-delivered). TTL in seconds, length in digits.
OTP_TTL=300
OTP_LENGTH=6
# HMAC key used to sign OTPs so we never store plaintext.
OTP_HMAC_SECRET=change-me-otp-hmac-secret

# ── Super-admin bootstrap (used by `pnpm db:seed`) ──────────────────────────
SUPERADMIN_EMAIL=admin@trimly.test
SUPERADMIN_PHONE=+919999999999
SUPERADMIN_PASSWORD=ChangeMe!2026
SUPERADMIN_FULL_NAME=Trimly Super Admin

# ── Google OAuth (Sign-In with Google) ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:4000/api/v1/auth/google/callback

# ── Apple Sign-In ────────────────────────────────────────────────────────────
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Path to the .p8 key file (relative to repo root or absolute).
APPLE_PRIVATE_KEY_PATH=
APPLE_BUNDLE_ID=

# ── Razorpay (payments + route/split) ────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_WEBHOOK_URL=http://localhost:4000/api/v1/payments/razorpay/webhook
# Use Razorpay Route/Linked Account split for marketplace settlements.
RAZORPAY_USE_ROUTE=true

# ── Storage (AWS S3 or Cloudflare R2 with S3 API) ───────────────────────────
# Set STORAGE_PROVIDER=s3 or r2
STORAGE_PROVIDER=s3
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=trimly-uploads
S3_REGION=ap-south-1
S3_ENDPOINT=
# Cloudflare R2 endpoint (only if STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID=

# ── Firebase (FCM push notifications) ────────────────────────────────────────
FIREBASE_PROJECT_ID=
# Server key JSON (paste the whole service-account JSON, or set FIREBASE_CREDENTIALS_PATH)
FIREBASE_CREDENTIALS_PATH=
FIREBASE_APP_ID=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Trimly <no-reply@trimly.app>"

# ── SMS (Twilio or MSG91) ────────────────────────────────────────────────────
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=

# ── WhatsApp (WhatsApp Business Cloud API) ───────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ── Realtime (Socket.IO) ─────────────────────────────────────────────────────
SOCKET_IO_CORS_ORIGINS=http://localhost:3000

# ── Analytics (PostHog) ──────────────────────────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ── Google Maps (Places/Geocoding) ───────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Frontend (Next.js admin) ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Trimly Admin
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
