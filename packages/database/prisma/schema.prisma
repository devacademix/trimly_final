// ─────────────────────────────────────────────────────────────────────────────
// Trimly Business OS — Prisma Schema
// Enterprise Multi-Tenant Salon & Appointment Booking SaaS Platform.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  SALON_OWNER
  STAFF
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum AuthProvider {
  EMAIL
  OTP
  GOOGLE
  APPLE
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  CAPTURED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  WALLET
  CASH
}

enum RefundStatus {
  PENDING
  PROCESSED
  FAILED
}

enum WalletType {
  CUSTOMER
  SALON
  ADMIN
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BOOKING_PAYMENT
  BOOKING_REFUND
  COMMISSION_CHARGE
  SETTLEMENT
  SUBSCRIPTION_BUY
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  TRIALING
}

enum CouponType {
  FLAT
  PERCENTAGE
  REFERRAL
  FIRST_BOOKING
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
}

// ─── Core Identity ───────────────────────────────────────────────────────────

model User {
  id               String       @id @default(uuid()) @db.Uuid
  email            String?      @unique(map: "users_email_unique")
  phone            String?      @unique(map: "users_phone_unique")
  phoneNormalized  String?      @unique(map: "users_phone_normalized_unique")
  passwordHash     String?
  firstName        String?
  lastName         String?
  fullName         String?
  gender           Gender?
  dateOfBirth      DateTime?
  profileImageUrl  String?
  role             UserRole
  status           UserStatus   @default(PENDING_VERIFICATION)
  authProvider     AuthProvider @default(EMAIL)
  googleSubject    String?      @unique(map: "users_google_subject_unique")
  appleSubject     String?      @unique(map: "users_apple_subject_unique")
  emailVerifiedAt  DateTime?
  phoneVerifiedAt  DateTime?
  lastLoginAt      DateTime?
  biometricEnabled Boolean      @default(false)
  preferredLocale  String       @default("en")
  fcmToken         String?      // Latest Firebase Cloud Messaging device token
  referralCode     String?      @unique(map: "users_referral_code_unique")
  referredById     String?      @db.Uuid
  referredBy       User?        @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals        User[]       @relation("UserReferrals")
  tenantId         String?      @db.Uuid
  tenant           Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  sessions         UserSession[]
  staffProfile     StaffProfile?
  favorites        CustomerFavorite[]
  bookings         Booking[]
  reviews          Review[]
  memberships      UserMembership[]
  chatParticipants ChatParticipant[]
  sentMessages     ChatMessage[]

  @@index([tenantId], map: "users_tenant_id_idx")
  @@index([role, status], map: "users_role_status_idx")
  @@index([phoneNormalized], map: "users_phone_normalized_idx")
  @@index([referredById], map: "users_referred_by_idx")
  @@map("users")
}

model Tenant {
  id            String    @id @default(uuid()) @db.Uuid
  slug          String    @unique(map: "tenants_slug_unique")
  name          String
  legalName     String?
  description   String?
  gstNumber     String?   @unique(map: "tenants_gst_unique")
  panNumber     String?
  status        String    @default("PENDING_APPROVAL")
  isActive      Boolean   @default(true)
  ownerEmail    String?
  ownerPhone    String?
  logoUrl       String?
  coverImageUrl String?
  primaryCity   String?
  primaryCountry String   @default("IN")
  currency      String   @default("INR")
  timezone      String   @default("Asia/Kolkata")
  commissionPct Decimal?  @db.Decimal(5, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  users             User[]
  branches          Branch[]
  workingHours      WorkingHours[]
  breakHours        BreakHours[]
  holidays          Holiday[]
  serviceCategories ServiceCategory[]
  services          Service[]
  servicePackages   ServicePackage[]
  products          Product[]
  productCategories ProductCategory[]
  bookings          Booking[]
  settlements       Settlement[]
  coupons           Coupon[]
  memberships       Membership[]
  subscriptions     SalonSubscription[]
  expenses          Expense[]
  wallets           Wallet[]

  @@index([status, isActive], map: "tenants_status_active_idx")
  @@index([slug], map: "tenants_slug_idx")
  @@map("tenants")
}

// ─── Salon Structure ─────────────────────────────────────────────────────────

model Branch {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  address     String
  latitude    Float?
  longitude   Float?
  phone       String?
  email       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  staff       StaffProfile[] @relation("BranchStaff")
  bookings    Booking[]
  gallery     SalonGallery[]
  favorites   CustomerFavorite[]

  @@index([tenantId])
  @@map("branches")
}

model SalonGallery {
  id        String   @id @default(uuid()) @db.Uuid
  branchId  String   @db.Uuid
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  url       String
  mediaType String   @default("IMAGE") // IMAGE, VIDEO
  createdAt DateTime @default(now())

  @@map("salon_gallery")
}

model WorkingHours {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dayOfWeek Int      // 0 = Sunday, 6 = Saturday
  openTime  String   // HH:MM
  closeTime String   // HH:MM
  isOpen    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, dayOfWeek])
  @@map("working_hours")
}

model BreakHours {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dayOfWeek      Int
  startTime      String       // HH:MM
  endTime        String       // HH:MM
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("break_hours")
}

model Holiday {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date        DateTime  @db.Date
  description String?
  createdAt   DateTime  @default(now())

  @@unique([tenantId, date])
  @@map("holidays")
}

// ─── Staff ───────────────────────────────────────────────────────────────────

model StaffProfile {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @unique @db.Uuid
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId        String       @db.Uuid
  bio             String?
  specialities    String[]
  rating          Decimal      @default(0.0) @db.Decimal(3, 2)
  isAvailable     Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  branches        Branch[]     @relation("BranchStaff")
  services        Service[]    @relation("StaffServices")
  leaves          StaffLeave[]
  availabilities  StaffAvailability[]
  bookings        Booking[]

  @@index([tenantId])
  @@map("staff_profiles")
}

model StaffAvailability {
  id        String       @id @default(uuid()) @db.Uuid
  staffId   String       @db.Uuid
  staff     StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  dayOfWeek Int          // 0 to 6
  startTime String       // HH:MM
  endTime   String       // HH:MM
  isOpen    Boolean      @default(true)

  @@unique([staffId, dayOfWeek])
  @@map("staff_availabilities")
}

model StaffLeave {
  id        String       @id @default(uuid()) @db.Uuid
  staffId   String       @db.Uuid
  staff     StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime
  reason    String?
  isApproved Boolean     @default(false)
  createdAt DateTime     @default(now())

  @@map("staff_leaves")
}

// ─── Services & Packages ─────────────────────────────────────────────────────

model ServiceCategory {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  services    Service[]

  @@index([tenantId])
  @@map("service_categories")
}

model Service {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @db.Uuid
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId  String          @db.Uuid
  category    ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal         @db.Decimal(10, 2)
  duration    Int             // Duration in minutes
  gender      Gender          @default(OTHER)
  isActive    Boolean         @default(true)
  imageUrl    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  staffs       StaffProfile[]      @relation("StaffServices")
  packageItems ServicePackageItem[]
  bookingItems BookingItem[]

  @@index([tenantId])
  @@index([categoryId])
  @@map("services")
}

model ServicePackage {
  id          String               @id @default(uuid()) @db.Uuid
  tenantId    String               @db.Uuid
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal              @db.Decimal(10, 2)
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?

  items       ServicePackageItem[]

  @@index([tenantId])
  @@map("service_packages")
}

model ServicePackageItem {
  id        String         @id @default(uuid()) @db.Uuid
  packageId String         @db.Uuid
  package   ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  serviceId String         @db.Uuid
  service   Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([packageId, serviceId])
  @@map("service_package_items")
}

// ─── Booking Engine ──────────────────────────────────────────────────────────

model Booking {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @db.Uuid
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String        @db.Uuid
  branch      Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customerId  String        @db.Uuid
  customer    User          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staffId     String?       @db.Uuid
  staff       StaffProfile? @relation(fields: [staffId], references: [id], onDelete: SetNull)
  startTime   DateTime
  endTime     DateTime
  status      BookingStatus @default(PENDING)
  totalPrice  Decimal       @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items       BookingItem[]
  payments    Payment[]
  histories   BookingHistory[]

  @@index([tenantId])
  @@index([branchId])
  @@index([customerId])
  @@index([staffId])
  @@index([startTime, status])
  @@map("bookings")
}

model BookingItem {
  id        String   @id @default(uuid()) @db.Uuid
  bookingId String   @db.Uuid
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceId String   @db.Uuid
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  price     Decimal  @db.Decimal(10, 2)

  @@map("booking_items")
}

model BookingHistory {
  id        String        @id @default(uuid()) @db.Uuid
  bookingId String        @db.Uuid
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  status    BookingStatus
  notes     String?
  changedBy String?
  createdAt DateTime      @default(now())

  @@map("booking_histories")
}

model WaitingList {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  startTime DateTime
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("waiting_lists")
}

// ─── Payments & Wallets ──────────────────────────────────────────────────────

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  bookingId     String        @db.Uuid
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  amount        Decimal       @db.Decimal(10, 2)
  commissionFee Decimal       @db.Decimal(10, 2)
  taxFee        Decimal       @default(0.0) @db.Decimal(10, 2)
  salonCut      Decimal       @db.Decimal(10, 2)
  referenceId   String?       @unique // e.g. Razorpay Payment ID
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  refunds       Refund[]

  @@map("payments")
}

model Refund {
  id          String       @id @default(uuid()) @db.Uuid
  paymentId   String       @db.Uuid
  payment     Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  amount      Decimal      @db.Decimal(10, 2)
  status      RefundStatus @default(PENDING)
  referenceId String?      @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("refunds")
}

model Wallet {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String?    @unique @db.Uuid
  tenantId  String?    @unique @db.Uuid
  tenant    Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      WalletType
  balance   Decimal    @default(0.0) @db.Decimal(12, 2)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String            @id @default(uuid()) @db.Uuid
  walletId    String            @db.Uuid
  wallet      Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  amount      Decimal           @db.Decimal(12, 2)
  description String?
  referenceId String?
  createdAt   DateTime          @default(now())

  @@map("wallet_transactions")
}

model Settlement {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(12, 2)
  status      String   @default("PENDING") // PENDING, SETTLED, FAILED
  referenceId String?  @unique
  settledAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@map("settlements")
}

// ─── Subscriptions ───────────────────────────────────────────────────────────

model SubscriptionPlan {
  id              String             @id @default(uuid()) @db.Uuid
  name            String             @unique // Free, Starter, Professional, Enterprise
  description     String?
  price           Decimal            @db.Decimal(10, 2)
  billingPeriod   String             @default("MONTHLY") // MONTHLY, YEARLY
  branchLimit     Int                @default(1)
  staffLimit      Int                @default(2)
  bookingLimit    Int                @default(50)
  storageLimitMb  Int                @default(500)
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  subscriptions   SalonSubscription[]

  @@map("subscription_plans")
}

model SalonSubscription {
  id          String             @id @default(uuid()) @db.Uuid
  tenantId    String             @db.Uuid
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId      String             @db.Uuid
  plan        SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  status      SubscriptionStatus @default(TRIALING)
  startDate   DateTime
  endDate     DateTime
  autoRenew   Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  invoices    SubscriptionInvoice[]

  @@index([tenantId])
  @@map("salon_subscriptions")
}

model SubscriptionInvoice {
  id             String            @id @default(uuid()) @db.Uuid
  subscriptionId String            @db.Uuid
  subscription   SalonSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoiceNumber  String            @unique
  amount         Decimal           @db.Decimal(10, 2)
  tax            Decimal           @default(0.0) @db.Decimal(10, 2)
  isPaid         Boolean           @default(false)
  paidAt         DateTime?
  pdfUrl         String?
  createdAt      DateTime          @default(now())

  @@map("subscription_invoices")
}

// ─── Inventory & Products ────────────────────────────────────────────────────

model ProductCategory {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  products  Product[]

  @@index([tenantId])
  @@map("product_categories")
}

model Product {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @db.Uuid
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId  String           @db.Uuid
  category    ProductCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal          @db.Decimal(10, 2)
  sku         String?
  stockQty    Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  movements   InventoryMovement[]

  @@index([tenantId])
  @@map("products")
}

model InventoryMovement {
  id           String                @id @default(uuid()) @db.Uuid
  productId    String                @db.Uuid
  product      Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  movementType InventoryMovementType
  quantity     Int
  reason       String?
  createdAt    DateTime              @default(now())

  @@map("inventory_movements")
}

model Expense {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(10, 2)
  category    String
  notes       String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@map("expenses")
}

// ─── Coupons & Memberships ───────────────────────────────────────────────────

model Coupon {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code           String
  type           CouponType
  value          Decimal      @db.Decimal(10, 2) // Discount value
  maxDiscount    Decimal?     @db.Decimal(10, 2)
  minOrderVal    Decimal?     @db.Decimal(10, 2)
  usageLimit     Int?
  usedCount      Int          @default(0)
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  usages         CouponUsage[]

  @@unique([tenantId, code])
  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(uuid()) @db.Uuid
  couponId  String   @db.Uuid
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  orderId   String?  @db.Uuid
  createdAt DateTime @default(now())

  @@map("coupon_usages")
}

model Membership {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  pointsRate  Decimal  @default(1.0) @db.Decimal(5, 2) // e.g. 1 point per 100 spent
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userMemberships UserMembership[]

  @@index([tenantId])
  @@map("memberships")
}

model UserMembership {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @db.Uuid
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipId String     @db.Uuid
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  points       Int        @default(0)
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("user_memberships")
}

// ─── Reviews & Chat ──────────────────────────────────────────────────────────

model Review {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  salonId    String    @db.Uuid
  rating     Int       // 1 to 5
  comment    String?
  imageUrls  String[]
  likesCount Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  replies    ReviewReply[]

  @@index([salonId])
  @@map("reviews")
}

model ReviewReply {
  id        String   @id @default(uuid()) @db.Uuid
  reviewId  String   @db.Uuid
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  authorId  String   @db.Uuid
  replyText String
  createdAt DateTime @default(now())

  @@map("review_replies")
}

model ChatRoom {
  id        String            @id @default(uuid()) @db.Uuid
  createdAt DateTime          @default(now())

  participants ChatParticipant[]
  messages     ChatMessage[]

  @@map("chat_rooms")
}

model ChatParticipant {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @db.Uuid
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@map("chat_participants")
}

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @db.Uuid
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  String   @db.Uuid
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  text      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("chat_messages")
}

// ─── Platform Settings & Audits ──────────────────────────────────────────────

model Setting {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique(map: "settings_key_unique")
  value       Json
  updatedAt   DateTime @updatedAt
  updatedById String?  @db.Uuid

  @@map("settings")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid
  actorRole  String?
  tenantId   String?  @db.Uuid
  action     String
  entityType String
  entityId   String?  @db.Uuid
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  requestId  String?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt], map: "audit_logs_tenant_created_idx")
  @@index([actorId, createdAt], map: "audit_logs_actor_created_idx")
  @@index([entityType, entityId], map: "audit_logs_entity_idx")
  @@map("audit_logs")
}

model UserSession {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String?  @db.VarChar(255)
  deviceType       String?  @db.VarChar(50)
  deviceId         String?  @db.VarChar(255)
  ipAddress        String?  @db.VarChar(45)
  userAgent        String?  @db.VarChar(512)
  isActive         Boolean  @default(true)
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId], map: "user_sessions_user_idx")
  @@index([refreshTokenHash], map: "user_sessions_token_idx")
  @@map("user_sessions")
}

model OtpSecret {
  id              String   @id @default(uuid()) @db.Uuid
  phoneNormalized String   @unique(map: "otp_secrets_phone_unique")
  otpHash         String   @db.VarChar(255)
  attempts        Int      @default(0)
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([phoneNormalized], map: "otp_secrets_phone_idx")
  @@map("otp_secrets")
}

model CustomerFavorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId  String   @db.Uuid
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, branchId])
  @@map("customer_favorites")
}
