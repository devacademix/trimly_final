{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Trimly Next.js",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2023"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "resolveJsonModule": true
  }
}
